# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...       # Service role key (full access)

# Firebase
FIREBASE_SERVICE_ACCOUNT='{...}'   # JSON string of service account key

# JWT
PELKO_JWT_SECRET=your-256-bit-secret
PELKO_JWT_EXPIRY=1h
PELKO_REFRESH_EXPIRY=30d

# Push notifications
APNS_KEY_ID=...
APNS_TEAM_ID=...
APNS_PRIVATE_KEY=...
FCM_SERVER_KEY=...

# SMS fallback
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Email
RESEND_API_KEY=re_...

# Apple Sign In
APPLE_CLIENT_ID=...               # Your app's bundle ID
APPLE_TEAM_ID=...

# Google Sign In
GOOGLE_CLIENT_ID=...

# Server
PORT=3000
