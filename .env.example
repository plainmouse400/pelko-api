# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...       # Service role key (full access)

# Firebase
FIREBASE_SERVICE_ACCOUNT='{...}'   # JSON string of service account key

# JWT
PELKO_JWT_SECRET=your-256-bit-secret
PELKO_JWT_EXPIRY=1h
PELKO_REFRESH_EXPIRY=30d

# Push notifications
APNS_KEY_ID=...
APNS_TEAM_ID=...
APNS_PRIVATE_KEY=...
FCM_SERVER_KEY=...

# SMS fallback
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Email
RESEND_API_KEY=re_...

# Apple Sign In
APPLE_CLIENT_ID=...               # Your app's bundle ID
APPLE_TEAM_ID=...

# Google Sign In
GOOGLE_CLIENT_ID=...

# App provisioning
GITHUB_TOKEN=ghp_...                   # GitHub personal access token with repo scope (pelko-apps org)
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...               # Cloudflare API token with Pages and Workers edit permissions

# Firebase (server-side service account for Workers)
FIREBASE_PROJECT_ID=...
FIREBASE_SERVICE_EMAIL=...             # service-account@project.iam.gserviceaccount.com
FIREBASE_SERVICE_KEY=...               # PEM private key from service account JSON

# Firebase (client-side web config, injected into generated frontend code)
FIREBASE_WEB_API_KEY=...
FIREBASE_AUTH_DOMAIN=...
FIREBASE_STORAGE_BUCKET=...
FIREBASE_MESSAGING_SENDER_ID=...
FIREBASE_WEB_APP_ID=...

# Server
PORT=3000
